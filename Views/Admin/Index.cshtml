@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-4">

    <h2 class="mb-5 text-center fw-bold">Admin Dashboard</h2>

    <!-- Statistics Cards -->
    <div class="row g-4">

        <div class="col-md-3">
            <div class="card shadow-sm text-center p-4 border-0">
                <div class="mb-2 fs-2">👤</div>
                <h6 class="text-muted">Total Users</h6>
                <h3 class="text-primary">@ViewBag.TotalUsers</h3>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm text-center p-4 border-0">
                <div class="mb-2 fs-2">🏦</div>
                <h6 class="text-muted">Total Accounts</h6>
                <h3 class="text-success">@ViewBag.TotalAccounts</h3>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm text-center p-4 border-0">
                <div class="mb-2 fs-2">💳</div>
                <h6 class="text-muted">Total Cards</h6>
                <h3 class="text-warning">@ViewBag.TotalCards</h3>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm text-center p-4 border-0">
                <div class="mb-2 fs-2">💰</div>
                <h6 class="text-muted">Transactions Today</h6>
                <h3 class="text-danger">@ViewBag.TotalTransactions</h3>
            </div>
        </div>

    </div>


    <!-- Quick Actions -->
    <h4 class="mt-5 mb-3 text-center">Admin Actions</h4>

    <div class="row g-4">

        <div class="col-md-3">
            <a asp-controller="Admin" asp-action="Users" class="text-decoration-none">
                <div class="card shadow-sm text-center p-4 border-0 action-card">
                    <div class="fs-3 mb-2">👥</div>
                    <h6>Manage Users</h6>
                </div>
            </a>
        </div>

        <div class="col-md-3">
            <a asp-controller="Admin" asp-action="Accounts" class="text-decoration-none">
                <div class="card shadow-sm text-center p-4 border-0 action-card">
                    <div class="fs-3 mb-2">🏦</div>
                    <h6>Manage Accounts</h6>
                </div>
            </a>
        </div>

        <div class="col-md-3">
            <a asp-controller="Admin" asp-action="Cards" class="text-decoration-none">
                <div class="card shadow-sm text-center p-4 border-0 action-card">
                    <div class="fs-3 mb-2">💳</div>
                    <h6>Manage Cards</h6>
                </div>
            </a>
        </div>

        <div class="col-md-3">
            <a asp-controller="Admin" asp-action="Transactions" class="text-decoration-none">
                <div class="card shadow-sm text-center p-4 border-0 action-card">
                    <div class="fs-3 mb-2">📊</div>
                    <h6>Transactions History</h6>
                </div>
            </a>
        </div>

    </div>

    <hr class="my-3" />

    <h4 class="mb-3 text-center">Recent Transactions</h4>

    <div class="card shadow-sm">
        <div class="card-body">

            <table class="table table-striped table-hover text-center">

                <thead class="table-dark">
                    <tr>
                        <th>Transaction Id</th>
                        <th>Account Id</th>
                        <th>Type</th>
                        <th>Amount</th>
                        <th>Date</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var t in ViewBag.RecentTransactions)
                    {
                        <tr>
                            <td>@t.TransactionId</td>
                            <td>@t.AccountId</td>
                            <td>@t.TransactionType</td>
                            <td>₹ @t.Amount</td>
                            <td>@t.TransactionDate.ToString("dd MMM yyyy HH:mm")</td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>
    </div>

</div>

<style>

    .card{
        border-radius:12px;
    }

    .action-card{
        transition:0.3s;
    }

    .action-card:hover{
        transform:translateY(-5px);
        box-shadow:0 8px 20px rgba(0,0,0,0.15);
    }

</style>