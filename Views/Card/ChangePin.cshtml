@model ATM_Simulation_System.Models.Card

@{
    ViewData["Title"] = "Change PIN";
}

<h1 class="mb-4 text-center">Change ATM PIN</h1>

<div class="row justify-content-center">
    <div class="col-md-4">

        @* Error Messages *@
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <form asp-action="ChangePin" method="post">

            <input type="hidden" name="accountId" value="@Model.AccountId" />

            <!-- Old PIN -->
            <div class="mb-3">
                <label class="form-label">Old PIN</label>
                <input id="oldPin" name="oldPin" type="password" maxlength="4"
                       pattern="[0-9]{4}" inputmode="numeric"
                       class="form-control" placeholder="Enter Old PIN" required />
            </div>

            <!-- New PIN -->
            <div class="mb-3">
                <label class="form-label">New PIN</label>
                <input id="newPin" name="newPin" type="password" maxlength="4"
                       pattern="[0-9]{4}" inputmode="numeric"
                       class="form-control" placeholder="Enter New PIN" required />
            </div>

            <!-- Confirm PIN -->
            <div class="mb-3">
                <label class="form-label">Confirm PIN</label>
                <input id="confirmPin" name="confirmPin" type="password" maxlength="4"
                       pattern="[0-9]{4}" inputmode="numeric"
                       class="form-control" placeholder="Confirm New PIN" required />
                <small id="pinMessage"></small>
            </div>

            <div class="mb-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary btn-sm flex-fill">
                    Change PIN
                </button>

                <a asp-controller="Dashboard" 
                    asp-action="AccountInfo"
                    asp-route-accountId="@Model.AccountId"
                   class="btn btn-secondary btn-sm flex-fill">
                    Back
                </a>
            </div>

        </form>

    </div>
</div>

@section Scripts {

    <script>

        const newPin = document.getElementById("newPin");
        const confirmPin = document.getElementById("confirmPin");
        const message = document.getElementById("pinMessage");

        function checkPin(){

            if(confirmPin.value.length === 0){
                message.innerHTML = "";
                return;
            }

            if(newPin.value === confirmPin.value){
                message.innerHTML = "PIN matched";
                message.style.color = "green";
            }
            else{
                message.innerHTML = "PIN does not match";
                message.style.color = "red";
            }

        }

        newPin.addEventListener("keyup", checkPin);
        confirmPin.addEventListener("keyup", checkPin);

        function allowDigitsOnly(input){

            input.addEventListener("input", function(){

                if(/[^0-9]/.test(this.value)){
                    this.value = this.value.replace(/[^0-9]/g,'');
                }

            });

        }

        allowDigitsOnly(document.getElementById("oldPin"));
        allowDigitsOnly(document.getElementById("newPin"));
        allowDigitsOnly(document.getElementById("confirmPin"));

    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}