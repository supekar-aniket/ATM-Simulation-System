@{
    ViewData["Title"] = "Home Page";
}

<div class="container mt-5">

    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">ATM Simulation System</h1>
        <p class="lead text-muted">
            Secure and simple banking simulation for account management,
            deposits, withdrawals and balance tracking.
        </p>
    </div>

    <div class="row justify-content-center">

        <div class="col-md-8">
            <div class="card shadow-lg border-0">
                <div class="card-body text-center p-5">

                    <h3 class="mb-4">Welcome to Digital ATM</h3>

                    <p class="text-muted mb-4">
                        Manage your bank account securely. Create accounts,
                        deposit money, withdraw funds and check balance
                        anytime using our ATM simulation system.
                    </p>

                    <div class="d-flex justify-content-center gap-3">

                        <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary btn-lg">
                            Login
                        </a>

                        <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-outline-primary btn-lg">
                            Register
                        </a>

                    </div>

                </div>
            </div>
        </div>

    </div>

</div>